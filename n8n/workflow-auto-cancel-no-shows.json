        "operation": "delete",
        "calendar": {
          "__rl": true,
          "value": "c_36b4c6c75706ffff8b32d991f27c2ac8e0b338cfd8d2c580259d7e8fb02fd191@group.calendar.google.com",
          "mode": "id"
        },
        "eventId": "={{ $json.eventId }}"
      },
      "id": "4a4a4a4a-aaaa-bbbb-cccc-444444444444",
